{
  "name": "deepresearch-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "typeorm migration:generate -d ormconfig.ts src/migrations",
    "migration:run": "typeorm migration:run -d ormconfig.ts",
    "migration:revert": "typeorm migration:revert -d ormconfig.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.79.0",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.44.0",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^8.57.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  }
}
