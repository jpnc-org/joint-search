# ── Postgres ──
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=deepresearch
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── MinIO / S3 ──
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=uploads
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1

# ── Redis (BullMQ queue) ──
REDIS_HOST=redis
REDIS_PORT=6379

# ── Qdrant (vector DB) ──
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ── Docling-Serve (document extraction) ──
DOCLING_SERVE_URL=http://docling-serve:5001

# ── Embeddings (OpenRouter, OpenAI-compatible) ──
EMBEDDING_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMS=1536

# ── JWT ──
JWT_SECRET=changeme-jwt-secret
JWT_REFRESH_SECRET=changeme-refresh-secret
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── App ──
MAX_FILE_SIZE=52428800
NODE_ENV=development
PORT=3001
